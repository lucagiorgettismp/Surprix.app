{
  "rules": {
    ".read":  "root.child('uids').child(auth.uid).child('admin').exists()",
    ".write": "root.child('uids').child(auth.uid).child('admin').exists()",
    "missings": {
      ".read": "root.child('uids').child(auth.uid).child('admin').exists()",
      "$user_id": {
        ".read": true,
        ".write": "$user_id === root.child('uids').child(auth.uid).child('username').val() || root.child('uids').child(auth.uid).child('admin').exists()"
      }
    },
    "producers": {
      ".read": "auth !== null",
      ".write": "root.child('uids').child(auth.uid).child('admin').exists()",
      ".indexOn": ["order"]
    },
    "sets": {
      ".read": "auth !== null",
      ".write": "root.child('uids').child(auth.uid).child('admin').exists()",
      ".indexOn": ["year_id"]
    },
    "surprise_doubles": {
      "$surp_id": {
        ".read": "auth !== null",
        "$user_id": {
          ".write": "$user_id === root.child('uids').child(auth.uid).child('username').val() || root.child('uids').child(auth.uid).child('admin').exists()"
        }
      }
    },
    "surprises": {
      ".read": true,
      ".write": "root.child('uids').child(auth.uid).child('admin').exists()",
      ".indexOn": ["set_id"]
    },
    "uids": {
      "$uid": {
        ".read": true,
        ".write": true
      }
    },
    "user_doubles": {
      ".read": true,
      "$user_id": {
        ".write": "$user_id === root.child('uids').child(auth.uid).child('username').val() || root.child('uids').child(auth.uid).child('admin').exists()"
      }
    },
    "users": {
      ".read": true,
      "$user_id": {
        ".write": "$user_id === root.child('uids').child(auth.uid).child('username').val() || root.child('uids').child(auth.uid).child('admin').exists()"
      }
    },
    "years": {
      ".read": "auth !== null",
      ".write": "root.child('uids').child(auth.uid).child('admin').exists()",
      ".indexOn": ["year", "producerId"]
    },
    "feedback": {
      "$targetUsername": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "chats": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "userChats": {
      "$username": {
        ".read": "auth != null && root.child('uids').child(auth.uid).child('username').val() === $username",
        ".write": "auth != null"
      }
    },
    "chatDeletions": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
